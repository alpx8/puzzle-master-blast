  "component_guidelines": {
    "Button": {
      "description": "Primary action elements. Must feel tappable.",
      "styles": {
        "primary": {
          "backgroundColor": "#39FF14",
          "borderRadius": 16,
          "paddingVertical": 16,
          "paddingHorizontal": 32,
          "alignItems": "center",
          "shadowColor": "#39FF14",
          "shadowOpacity": 0.4,
          "shadowRadius": 8,
          "elevation": 6
        },
        "secondary": {
          "backgroundColor": "#1A1A3F",
          "borderRadius": 12,
          "padding": 12,
          "borderWidth": 1,
          "borderColor": "rgba(255,255,255,0.1)"
        },
        "text_primary": {
          "color": "#0A0A1A",
          "fontWeight": "900",
          "fontSize": 18,
          "textTransform": "uppercase",
          "letterSpacing": 1
        }
      }
    },
    "Card": {
      "description": "Container for content. Glass-like or solid dark.",
      "styles": {
        "container": {
          "backgroundColor": "#11112B",
          "borderRadius": 24,
          "padding": 20,
          "borderWidth": 1,
          "borderColor": "rgba(255,255,255,0.05)"
        }
      }
    },
    "GameBoard": {
      "description": "The 8x8 Grid. Must be perfectly square.",
      "styles": {
        "grid_container": {
          "backgroundColor": "#050510",
          "borderRadius": 12,
          "padding": 8,
          "aspectRatio": 1,
          "flexDirection": "row",
          "flexWrap": "wrap",
          "justifyContent": "center",
          "alignContent": "center"
        },
        "cell": {
          "backgroundColor": "rgba(255,255,255,0.03)",
          "borderRadius": 4,
          "margin": 2
        }
      }
    }
  },
  "layout_strategies": {
    "Screen": {
      "safe_area": "Use SafeAreaView from react-native-safe-area-context",
      "background": "Fill with #0A0A1A",
      "padding": "px-4 or px-6 equivalent (16px / 24px)"
    },
    "Header": {
      "height": 60,
      "alignment": "row, space-between, center",
      "typography": "text-2xl, heavy weight"
    },
    "BottomNav": {
      "style": "Floating pill shape at bottom, not full width bar. Glassmorphism effect."
    }
  },
  "animation_rules": {
    "BlockDrag": "Use PanGestureHandler + Reanimated. Scale up block to 1.1x when picked up.",
    "BlockPlace": "Spring animation (mass: 1, stiffness: 200, damping: 20) when snapping to grid.",
    "RowClear": "Flash row white/bright, then shrink height to 0 with opacity fade out.",
    "ScreenTransition": "Slide from right or FadeScale."
  },
  "instructions_to_main_agent": [
    "1. Do NOT assume Tailwind is installed. Use StyleSheet.create or inline styles with the design tokens provided.",
    "2. If you need gradients, use 'expo-linear-gradient'.",
    "3. For the 8x8 grid, ensure you calculate cell size dynamically based on screen width: (Dimensions.get('window').width - padding) / 8.",
    "4. Blocks must be solid colors from the 'blocks' palette. No transparency on the block itself, only on the 'ghost' preview.",
    "5. Use the provided image URLs for specific UI elements like icons or backgrounds. Use <Image /> component.",
    "6. Ensure all touch targets are at least 44x44 points.",
    "7. Add 'data-testid' to all interactables."
  ]
}