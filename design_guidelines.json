{
  "identity": {
    "persona": "E1: The Anti-AI Designer",
    "mission": "Create a visceral, dopamine-inducing arcade experience that feels like a premium instrument, not a cheap toy. Every pixel must pop against the void.",
    "principles": [
      "Darkness is the Canvas: The background is not just black; it is the void where light (content) lives.",
      "Neon is Life: Blocks and interactive elements must glow and feel physical.",
      "Motion is Feedback: Every touch, drag, and score must have kinetic consequences.",
      "Premium Polish: No jagged edges, no default fonts, no flat colors without purpose."
    ]
  },
  "tech_stack": {
    "framework": "React Native (Expo)",
    "styling": "StyleSheet with Design Tokens (NativeWind / Tailwind concepts applied manually or via library if available)",
    "animation": "react-native-reanimated",
    "icons": "@expo/vector-icons",
    "gestures": "react-native-gesture-handler"
  },
  "design_tokens": {
    "colors": {
