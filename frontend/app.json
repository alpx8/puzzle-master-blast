{
  "expo": {
    "name": "Puzzle Master Blast",
    "slug": "puzzle-master-blast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "puzzlemasterblast",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-image.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.puzzlemasterblast.app",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false,
        "googleMobileAdsAppId": "ca-app-pub-1839067347385099~5884338608"
      }
    },
    "android": {
      "package": "com.puzzlemasterblast.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0a1a"
      },
      "permissions": [
        "INTERNET",
        "VIBRATE",
        "ACCESS_NETWORK_STATE",
        "com.google.android.gms.permission.AD_ID"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-1839067347385099~5884338608"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a0a1a"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-1839067347385099~5884338608",
          "iosAppId": "ca-app-pub-1839067347385099~5884338608",
          "delayAppMeasurementInit": false,
          "userTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "5d68f9ae-3d6e-4eda-a35d-cb5b87043147"
      }
    },
    "owner": "alpx88",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5d68f9ae-3d6e-4eda-a35d-cb5b87043147"
    }
  }
}
